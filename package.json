{
  "name": "almi-italian",
  "version": "0.1.0",
  "description": "AlmiItalian — honest CILS + CELI exam practice. Three isolated scoring engines (CILS standard, CILS B1 Cittadinanza, CELI); Writing/Speaking = AI estimate.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run seo:test && prisma generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "seo:data": "python scripts/seo/build-data.py",
    "seo:test": "node scripts/seo/exclusions.selftest.mjs && tsx scripts/seo/content.selftest.ts",
    "selftest:engine": "tsx src/lib/scoring/scoring.selftest.ts",
    "validate:batch1": "tsx scripts/seed/batch1/batch1.selftest.ts",
    "seed:batch1": "tsx scripts/seed/seed-batch1.ts",
    "db:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "next": "16.2.6",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
